# ── App ───────────────────────────────────────────────
APP_NAME=HireFlow
DEBUG=true
API_PREFIX=/api/v1

# ── Database ──────────────────────────────────────────
# Dev (SQLite)
DATABASE_URL=sqlite:///./hireflow_dev.db

# Prod (PostgreSQL + pgvector)
# DATABASE_URL=postgresql://user:password@localhost:5432/hireflow

# ── Redis + Celery ────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── AI ────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=gpt-4o-mini

# ── Vector DB ─────────────────────────────────────────
VECTOR_BACKEND=pgvector      # pgvector | pinecone
PINECONE_API_KEY=
PINECONE_ENV=
PINECONE_INDEX=hireflow

# ── Storage ───────────────────────────────────────────
STORAGE_BACKEND=local        # local | s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=ap-south-1

# ── Auth ──────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── Email ─────────────────────────────────────────────
SENDGRID_API_KEY=
FROM_EMAIL=noreply@hireflow.in

# ── Payments ──────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
```

